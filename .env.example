# Copy this file to .env and fill in your values
# Never commit .env to git

# Preferred: Groq API key (free, fast — llama-3.3-70b-versatile)
GROQ_API_KEY=gsk_...

# Fallback: OpenAI API key (used if GROQ_API_KEY is missing or fails)
OPENAI_API_KEY=sk-proj-...

# Optional: GitHub Personal Access Token (only needed if hitting rate limits)
# Without token: 60 requests/hour per IP (enough for this use case)
# GITHUB_TOKEN=ghp_...
